# --- PostgreSQL Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rag_db

# --- Minio Configuration ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=rag-documents
# Use 'localhost' if running locally, or the container name if inside docker network
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Qdrant Configuration ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- FastAPI Application ---
APP_SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM Provider (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
