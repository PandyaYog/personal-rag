# --- PostgreSQL Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rag_db

# --- Storage Configuration (Cloudflare R2) ---
R2_ENDPOINT=your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_r2_bucket_name

# --- Redis Configuration (Upstash) ---
REDIS_URL=rediss://default:your_upstash_password@your-upstash-host.upstash.io:6379?ssl_cert_reqs=CERT_NONE

# --- Qdrant Configuration ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- FastAPI Application ---
APP_SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Embedding Service (Hugging Face Space) ---
EMBEDDING_SERVICE_URL=https://your-hf-space-url.hf.space
EMBEDDING_SERVICE_API_KEY=your_hf_api_key

# --- Frontend Configuration ---
FRONTEND_URL=http://localhost:5173

# --- LLM Provider (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Email Configuration ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True
